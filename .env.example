# Bearer token protecting /api/* and /mcp* — pick something long and random,
# e.g. `openssl rand -hex 32`.
MCP_SKILLS_TOKEN=change-me

# Trusted local network escape hatch: set to true to disable bearer auth
# entirely (no token needed for /api or /mcp). Overrides the token above.
# Leave unset/false unless the server is unreachable from untrusted networks.
# SECURE_LOCAL_NET=true
