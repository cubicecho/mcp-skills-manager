<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} · {{ site.name }}{% else %}{{ site.name }} — {{ site.tagline }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta property="og:title" content="{{ title or site.name }}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ site.url }}" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%93%9A%3C/text%3E%3C/svg%3E" />
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="{{ '/' | url }}">
          <span class="brand-mark" aria-hidden="true">📚</span>
          <span class="brand-name">{{ site.name }}</span>
        </a>
        <nav class="site-nav">
          <a href="{{ '/' | url }}"{% if page.url == '/' %} aria-current="page"{% endif %}>Home</a>
          <a href="{{ '/get-started/' | url }}"{% if page.url == '/get-started/' %} aria-current="page"{% endif %}>Get started</a>
          <a href="{{ '/docs/' | url }}"{% if page.url == '/docs/' %} aria-current="page"{% endif %}>Docs</a>
          <a class="nav-external" href="{{ site.repo }}">GitHub ↗</a>
        </nav>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <div class="lightbox" hidden>
      <button class="lightbox-close" type="button" aria-label="Close">×</button>
      <img class="lightbox-img" src="" alt="" />
    </div>
    <script>
      // Click any <img class="zoomable"> to open it full-size in the shared lightbox.
      (function () {
        const box = document.querySelector('.lightbox');
        if (!box) return;
        const img = box.querySelector('.lightbox-img');
        const open = (src, alt) => {
          img.src = src;
          img.alt = alt || '';
          box.hidden = false;
          document.body.style.overflow = 'hidden';
        };
        const close = () => {
          box.hidden = true;
          img.src = '';
          document.body.style.overflow = '';
        };
        document.addEventListener('click', (e) => {
          const z = e.target.closest('img.zoomable');
          if (z) { open(z.currentSrc || z.src, z.alt); return; }
          if (e.target === box || e.target.closest('.lightbox-close')) close();
        });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !box.hidden) close(); });
      })();
    </script>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p>{{ site.name }} — an MCP skills server. Not affiliated with Anthropic or the MCP project.</p>
        <p class="footer-links">
          <a href="{{ site.repo }}">Source</a>
          <a href="{{ site.dockerHub }}">Docker Hub</a>
          <a href="{{ '/docs/' | url }}">Docs</a>
          <a href="https://modelcontextprotocol.io">Model Context Protocol</a>
        </p>
      </div>
    </footer>
  </body>
</html>
